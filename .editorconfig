# Bastille Blockchain — editor formatting conventions
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Elixir / Erlang
[*.{ex,exs,erl,hrl}]
indent_size = 2

# Rust NIF
[*.rs]
indent_size = 4

# Config & data formats
[*.{json,yml,yaml,toml}]
indent_size = 2

# Markdown — keep trailing whitespace (hard line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[{Makefile,*.mk}]
indent_style = tab
